{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/self-drive-rental",
      "destination": "/Public/self-drive-rental"
    },
    {
      "source": "/with-driver-rental",
      "destination": "/Public/with-driver-rental"
    },
    {
      "source": "/inbound-outbound-transfers",
      "destination": "/Public/inbound-outbound-transfers"
    },
    {
      "source": "/app.js",
      "destination": "/Public/app.js"
    },
    {
      "source": "/auth-utils.js",
      "destination": "/Public/auth-utils.js"
    },
    {
      "source": "/dashboard.js",
      "destination": "/Public/dashboard.js"
    },
    {
      "source": "/styles.css",
      "destination": "/Public/styles.css"
    },
    {
      "source": "/dashboard-style.css",
      "destination": "/Public/dashboard-style.css"
    },
    {
      "source": "/robots.txt",
      "destination": "/Public/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/Public/sitemap.xml"
    },
    {
      "source": "/images/:path*",
      "destination": "/Public/images/:path*"
    },
    {
      "source": "/images.2/:path*",
      "destination": "/Public/images.2/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://api.mayonrentacar.com.ph/api/:path*"
    }
  ]
}